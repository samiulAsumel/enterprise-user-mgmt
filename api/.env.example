# Copy to .env and fill in before starting the API.
# The install.sh script generates .env automatically.

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_BYTES

# JWT token expiry
JWT_EXPIRY=8h

# API listen port (nginx proxies to this)
PORT=3001

# Path to admins config (created by install.sh)
ADMINS_FILE=/etc/user-mgmt/admins.json

# Path to audit log
AUDIT_LOG=/var/log/user-mgmt/api-audit.log

# Allowed shells for useradd (comma-separated)
ALLOWED_SHELLS=/bin/bash,/bin/zsh,/bin/sh,/sbin/nologin,/bin/false

# Minimum UID for regular users
UID_MIN=1000
